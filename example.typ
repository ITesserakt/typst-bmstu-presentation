#slide("Введение", subtitle: "Пример слайда. Матрица трафика")[
  #show: shaded

  #grid(columns: (54%, 46%), row-gutter: 1em,
    {
      [Рассмотрим ориентированный граф $G = (V, E)$, где $|V| = n$, $|E| = n$.]
      arrow-list(
        [*Течение трафика*: поток байтов, отправленных из узла $i$ в узел $j$ за фиксированное время.],
        [
          *Матрица трафика $X$* определяет \# байт $X_"ij"$ для каждой пары узлов.
            - #text(size: 0.8em)[Вложенный список. Дополнительный элемент.]
            - #text(size: 0.8em)[Другой элемент]
              + #text(size: 0.8em)[Перечисление]
              + #text(size: 0.8em)[...]
        ]
      )
    },
    figure(caption: "Пример подписи", box(width: 150pt, height: 150pt, {
      let points(range, radius: 2.65cm) = {
        let count = 2 / range.len()
        range.map(it => (calc.cos(count * it * calc.pi), calc.sin(count * it * calc.pi))).map(it => (it.at(0) * radius, it.at(1) * radius))
      }

      place(dx: 2.65cm, dy: 2.65cm, polygon(
        stroke: 0.1mm,
        ..points(range(10))
      ))

      place(dx: 2.65cm, dy: 2.65cm, polygon(
        stroke: 0.1mm,
        ..points(range(5))
      ))

      place(dy: 0.15cm, rotate(180deg, polygon(
        stroke: 0.1mm,
        ..points(range(5))
      )))

      points(range(10)).map(it => place(center + horizon, dx: it.at(0), dy: it.at(1), circle(fill: red, radius: 1mm))).join()
    })),
    grid.cell(colspan: 2, [
      - *Счётчик связей $Y$* определяет \# байт $Y_"ij"$, прошедших через ребро, соединяющее узел $i$ с узлом $j$ (матрица смежности с весами).
    ])
  )
]

